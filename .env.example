# OpenWeatherMap — free: https://openweathermap.org/api → sign up → API keys (activation can take ~2h)
VITE_OPENWEATHER_API_KEY=

# Gmail (Sanctuary Inbox) — required for Sync Gmail:
# 1) Enable API: https://console.cloud.google.com/apis/library/gmail.googleapis.com
# 2) OAuth consent screen (APIs & Services → OAuth consent screen): External, add your email as a
#    test user while the app is in "Testing". Add scopes: .../auth/gmail.modify and .../auth/gmail.send
#    (or use "Add or remove scopes" and pick Gmail modify + send).
# 3) Credentials → Create credentials → OAuth client ID → Application type: Web application.
#    Authorized JavaScript origins: http://localhost:5173 (and your production URL if any).
#    You do not need a redirect URI for this app (Google Identity Services token flow).
# 4) Paste the Client ID (ends in .apps.googleusercontent.com) below, save, restart: npm run dev
VITE_GOOGLE_CLIENT_ID=

# Optional: dev bypass for auth
# VITE_ENABLE_AUTH_BYPASS=true
