# Copy to `.env` and fill in your key (free tier: https://openweathermap.org/api)
VITE_OPENWEATHER_API_KEY=

# Gmail: create an OAuth 2.0 Web client in Google Cloud Console, enable Gmail API,
# add Authorized JavaScript origins (e.g. http://localhost:5173) and use the client ID here.
VITE_GOOGLE_CLIENT_ID=

# Optional: dev bypass for auth
# VITE_ENABLE_AUTH_BYPASS=true
